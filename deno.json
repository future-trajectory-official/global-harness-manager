      "tags": ["recommended"]
    }
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/tar": "jsr:@std/tar@^0.1.3",
    "fflate": "npm:fflate@^0.8.2"
  }
}
