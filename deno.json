{
  "compilerOptions": {
    "lib": ["deno.window", "deno.ns"]
  },
  "tasks": {
    "test": "deno test -A --parallel",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check **/*.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/tar": "jsr:@std/tar@^0.1.3",
    "@std/assert": "jsr:@std/assert@^1.0.7",
    "@std/testing": "jsr:@std/testing@^1.0.9",
    "fflate": "npm:fflate@^0.8.2"
  }
}
